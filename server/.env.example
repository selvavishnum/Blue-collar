# ─── Required ────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Auto-set by Railway ──────────────────────────────────────────────────────
# Railway injects PORT automatically — do not set manually
# PORT=3001

# ─── Optional ────────────────────────────────────────────────────────────────
# Only needed in local dev (production uses same-origin)
# FRONTEND_URL=http://localhost:5173

# Set this in Railway → Variables for production
NODE_ENV=production
