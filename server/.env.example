# ─── Required ────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey (free)
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Set in Render Dashboard → blue-collar-api → Environment ─────────────────
NODE_ENV=production

# Your Render frontend static site URL (set after first deploy)
# e.g. https://blue-collar-frontend.onrender.com
FRONTEND_URL=https://your-frontend.onrender.com

# ─── Auto-set by Render ───────────────────────────────────────────────────────
# PORT is injected by Render automatically — do NOT set manually
